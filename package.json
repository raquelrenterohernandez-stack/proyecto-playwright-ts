{
  "name": "proyecto-playwright-ts",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean-results": "rm -rf allure-results/*",
    "run-test": "npx playwright test --reporter=line,allure-playwright",
    "generate-report": "allure generate ./allure-results -o ./allure-report --clean",
    "open-report": "allure open ./allure-report",
    "local-test": "np run clean-results & npm run run-test & npm run generate-report & npm run open-report",
    "ci-test": "np run clean-results & npm run run-test & npm run generate-report"
  },
  "repository": {
    "type": "git",
